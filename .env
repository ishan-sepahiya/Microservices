# =============================================================================
# PLATFORM — ROOT ENVIRONMENT
# Generate secrets: openssl rand -hex 32
# =============================================================================

# ── Shared JWT (all services verify with this) ────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── REST: Product Service ─────────────────────────────────────────────────────
PRODUCT_DATABASE_URL=postgresql+asyncpg://postgres:changeme@product-db:5432/product_db
PRODUCT_SERVICE_URL=http://product-service:8001

# ── REST: Payment Service ─────────────────────────────────────────────────────
PAYMENT_DATABASE_URL=postgresql+asyncpg://postgres:changeme@payment-db:5432/payment_db
PAYMENT_SERVICE_URL=http://payment-service:8002

# ── WS: Chat Service ──────────────────────────────────────────────────────────
CHAT_DATABASE_URL=postgresql+asyncpg://postgres:changeme@chat-db:5432/chat_db
CHAT_SERVICE_URL=http://chat-service:8011

# ── WS: Metrics Service ───────────────────────────────────────────────────────
METRICS_DATABASE_URL=postgresql+asyncpg://postgres:changeme@metrics-db:5432/metrics_db
METRICS_SERVICE_URL=http://metrics-service:8012

# ── Agent Control API ─────────────────────────────────────────────────────────
AGENT_DATABASE_URL=postgresql+asyncpg://postgres:changeme@agent-db:5432/agent_db
AGENT_SERVICE_URL=http://agent:8020
AGENT_API_KEY=change-me-agent-internal-key

# ── REST Gateway ──────────────────────────────────────────────────────────────
REST_GATEWAY_PORT=8000

# ── WS Gateway ────────────────────────────────────────────────────────────────
WS_GATEWAY_PORT=9000

# ── Agent AI ──────────────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=mistral

# ── n8n Webhooks (optional) ───────────────────────────────────────────────────
N8N_SCALE_WEBHOOK=
N8N_RESTART_WEBHOOK=
N8N_ROLLBACK_WEBHOOK=
N8N_DEBUG_WEBHOOK=

# ── OTel ──────────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
