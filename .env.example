# ==========================================
# MICROSERVICES CONFIGURATION
# ==========================================
# Copy this file to .env and fill in with your actual values
# NEVER commit secrets to version control!

# ──────────────────────────────────────────
# DATABASE & PERSISTENCE
# ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/microservices
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ──────────────────────────────────────────
# SECURITY & JWT
# ──────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────
# AGENT SERVICE
# ──────────────────────────────────────────
AGENT_API_KEY=change-me-agent-internal-key
AGENT_SERVICE_URL=http://agent:8020

# Downstream Service URLs
PRODUCT_SERVICE_URL=http://product-service:8001
PAYMENT_SERVICE_URL=http://payment-service:8002
CHAT_SERVICE_URL=http://chat-service:8011
METRICS_SERVICE_URL=http://metrics-service:8012
USER_SERVICE_URL=http://user-service:8000

# ──────────────────────────────────────────
# AI/LLM CONFIGURATION
# ──────────────────────────────────────────
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=mistral

# ──────────────────────────────────────────
# n8n WEBHOOKS (Optional - for automation)
# ──────────────────────────────────────────
N8N_SCALE_WEBHOOK=
N8N_RESTART_WEBHOOK=
N8N_ROLLBACK_WEBHOOK=
N8N_DEBUG_WEBHOOK=

# ──────────────────────────────────────────
# MINIO / S3 STORAGE (File Service)
# ──────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads
MINIO_SECURE=False

# ──────────────────────────────────────────
# EMAIL / SMTP (Notification Service)
# ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=SaaS Platform

# ──────────────────────────────────────────
# SMS / TWILIO (Notification Service)
# ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────────────────
# OBSERVABILITY
# ──────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=microservices

# ──────────────────────────────────────────
# DEBUG MODE
# ──────────────────────────────────────────
DEBUG=False
